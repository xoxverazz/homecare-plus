# ── App ────────────────────────────────────────────────────────
APP_NAME=HomeCare+
APP_ENV=development
DEBUG=True

# ── Database (MySQL) ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=homecare_plus

# ── JWT ────────────────────────────────────────────────────────
SECRET_KEY=homecare-super-secret-key-change-in-production-min-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── File Storage ───────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── AI / LLM (optional — rule-based fallback if empty) ─────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Google Maps (optional) ─────────────────────────────────────
GOOGLE_MAPS_API_KEY=
